# 正式部署反向代理設定。
# 站台位址由環境變數 SITE_ADDRESS 決定(於 .env 設定,由 web 容器帶入):
#   未設定(預設):`:80` — 內網 IP 走 HTTP。
#   設為網域名(例 school.example.edu.tw):Caddy 自動申請並續期 HTTPS 憑證。
{
	admin off
}

{$SITE_ADDRESS::80} {
	# 請求體上限,防止(內部誤操作或被盜帳號的)超大上傳打爆單校主機記憶體。
	# 200MB 容得下真實資料庫還原的 .dump 與 Excel 匯入;超大資料庫還原改用 volume 複製法
	# (見 docs/deploy/backup.md),不走網頁上傳。
	request_body {
		max_size 200MB
	}

	# API 交給後端
	handle /api/* {
		reverse_proxy api:8000
	}

	# 其餘走前端 SPA,找不到檔案回退 index.html(支援 vue-router history 模式)
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	encode gzip
}
