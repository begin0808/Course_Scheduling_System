# 複製此檔為 .env,至少修改「管理員密碼」與「校名」兩項即可啟動。
#   cp .env.example .env

# ── 必改 ─────────────────────────────
# 系統管理員預設帳密(首次登入後會強制改密碼)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# 學校名稱(顯示於介面與匯出課表)
SCHOOL_NAME=示範學校
# 學校所在時區(用於「今日課表」「當日調代課」等判定)
TZ=Asia/Taipei
# session cookie 簽章金鑰(正式部署務必改成隨機長字串,例如 openssl rand -hex 32 的輸出)
SECRET_KEY=please-change-this-to-a-random-secret

# ── 網路 ─────────────────────────────
# 對外連接埠(預設 80;若被占用可改 8080 等)
HTTP_PORT=80

# ── 選配:網域與 HTTPS(校外連線時使用,見 docs/deploy/https.md)──
# 內網 IP 使用維持預設(不設 SITE_ADDRESS,走 HTTP)即可。
# 若有公開網域並要自動申請 HTTPS 憑證,設為你的網域名(需先把網域 A 記錄指向本主機):
# SITE_ADDRESS=school.example.edu.tw
# HTTPS_PORT=443

# ── 預建映像版本(僅「拉取映像」部署方式需要)──────────
# 用 docker compose pull 拉官方映像時,決定要拉哪一版。
# 預設 latest(最新);正式部署建議釘選版本號以利可控升級,例如:
# IMAGE_TAG=v1.0.0
# 若你是從原始碼 docker compose up -d 自行建置,此項可忽略。
IMAGE_TAG=latest

# ── 資料庫(單機部署維持預設即可;若改帳密需三者一致)──
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler
POSTGRES_DB=scheduler
DATABASE_URL=postgresql+psycopg://scheduler:scheduler@postgres:5432/scheduler

# ── 佇列 ─────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── 選填:寄信(未設定則僅站內通知,見 M4-3)──
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
