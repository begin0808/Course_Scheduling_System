# 複製此檔為 .env,至少修改「管理員密碼」與「校名」兩項即可啟動。
#   cp .env.example .env

# ── 必改 ─────────────────────────────
# 系統管理員預設帳密(首次登入後會強制改密碼)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# 學校名稱(顯示於介面與匯出課表)
SCHOOL_NAME=示範學校
# session cookie 簽章金鑰(正式部署務必改成隨機長字串,例如 openssl rand -hex 32 的輸出)
SECRET_KEY=please-change-this-to-a-random-secret

# ── 網路 ─────────────────────────────
# 對外連接埠(預設 80;若被占用可改 8080 等)
HTTP_PORT=80

# ── 資料庫(單機部署維持預設即可;若改帳密需三者一致)──
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler
POSTGRES_DB=scheduler
DATABASE_URL=postgresql+psycopg://scheduler:scheduler@postgres:5432/scheduler

# ── 佇列 ─────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── 選填:寄信(未設定則僅站內通知,見 M4-3)──
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
